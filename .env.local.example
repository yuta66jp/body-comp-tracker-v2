# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (オプション) ML バッチで Supabase に書き込む場合に使用
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# /api/career-logs の簡易保護用シークレット（本番では必ず変更すること）
# サーバー側チェック用（Route Handler 内で使用）
ADMIN_SECRET=change-me-in-production
# クライアント側から送信するために NEXT_PUBLIC_ プレフィックスが必要
# セキュリティ上の注意: この値はブラウザバンドルに含まれる。
# 本番環境では Supabase Auth 等の認証に移行することを強く推奨。
NEXT_PUBLIC_ADMIN_SECRET=change-me-in-production
